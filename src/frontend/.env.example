# Open Hallucination Index — frontend environment
#
# Only NEXT_PUBLIC_* vars are needed; the frontend is a fully static export
# (output: 'export'). There is no server-side code in production.

# Public API base URL. Production: Cloudflare-fronted Lambda on a sibling
# subdomain of the frontend apex.
NEXT_PUBLIC_API_BASE=https://api.ohi.shiftbloom.studio/api/v2

# Public site URL. Used for metadata, sitemap, OG image URLs.
NEXT_PUBLIC_SITE_URL=https://ohi.shiftbloom.studio

# Optional: when "true", shows a raw-JSON debug drawer on /verify.
NEXT_PUBLIC_SHOW_DEBUG=false

# ── Local dev ──
# To run against a local FastAPI (cd src/api && ohi-server):
#   cp .env.example .env.local
# and then uncomment:
# NEXT_PUBLIC_API_BASE=http://localhost:8080/api/v2
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
