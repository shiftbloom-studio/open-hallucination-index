# Benchmark output: keep the dir and the .gitkeep; keep committed baseline
# summary files (v1_baseline_*.summary.json) as Phase 0 acceptance
# artifacts; ignore raw JSONL + smoke-test outputs.
/benchmark_results/*
!/benchmark_results/.gitkeep
!/benchmark_results/v1_baseline_*.summary.json
!/benchmark_results/v2_*.summary.json

# ==============================================================================
# Internal design + planning docs (local only, not pushed)
# ==============================================================================
# Brainstorming specs, implementation plans, and checkpoint handoffs for the
# ongoing redesign are kept out of the remote while the work is in progress.
# If and when the design stabilizes, selected sections can be re-introduced
# (e.g., copied into README.md or docs/) under a separate explicit commit.
/docs/superpowers/

/gui_ingestion_app/.wiki_dumps/
